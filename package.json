{
  "name": "publindex-cli",
  "version": "1.0.0",
  "description": "Carga masiva de artículos en Publindex (Minciencias)",
  "main": "dist/bin/publindex.js",
  "bin": {
    "publindex": "./dist/bin/publindex.js"
  },
  "scripts": {
    "start": "tsx bin/publindex.ts",
    "build": "tsc",
    "build:bundle": "esbuild bin/publindex.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/publindex.js",
    "build:bin": "npm run ext:build && npm run embed:ext && npm run build:bundle && pkg dist/publindex.js --targets node20-win-x64,node20-macos-arm64,node20-macos-x64 --out-path dist/",
    "embed:ext": "node scripts/embed-extension.mjs",
    "test": "vitest run",
    "ext:build": "npm run build --prefix extension",
    "ext:dev": "npm run dev --prefix extension",
    "ext:test": "npm test --prefix extension"
  },
  "keywords": [
    "publindex",
    "minciencias",
    "articulos"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.7.1",
    "form-data": "^4.0.5",
    "inquirer": "^9.3.8",
    "ora": "^5.4.1",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "@yao-pkg/pkg": "^6.17.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.1"
  }
}
