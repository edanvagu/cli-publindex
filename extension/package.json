{
  "name": "publindex-extension",
  "version": "0.2.0",
  "private": true,
  "description": "Chromium extension that autofills Publindex forms from a CLI-generated Excel",
  "type": "module",
  "scripts": {
    "dev": "node build.mjs --watch",
    "build": "node build.mjs",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.28.0",
    "happy-dom": "^15.11.6",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
